{
  "name": "politty",
  "version": "0.5.1",
  "description": "A lightweight CLI framework inspired by citty with zod v4 registry integration for type-safe metadata management",
  "keywords": [
    "argument-parser",
    "cli",
    "command-line",
    "type-safe",
    "typescript",
    "zod"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toiroakr/politty.git",
    "directory": "packages/politty"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./augment": {
      "import": {
        "types": "./dist/augment.d.ts",
        "default": "./dist/augment.js"
      },
      "require": {
        "types": "./dist/augment.d.cts",
        "default": "./dist/augment.cjs"
      }
    },
    "./docs": {
      "import": {
        "types": "./dist/docs/index.d.ts",
        "default": "./dist/docs/index.js"
      },
      "require": {
        "types": "./dist/docs/index.d.cts",
        "default": "./dist/docs/index.cjs"
      }
    },
    "./docs/vitest": {
      "import": {
        "types": "./dist/docs/vitest.d.ts",
        "default": "./dist/docs/vitest.js"
      },
      "require": {
        "types": "./dist/docs/vitest.d.cts",
        "default": "./dist/docs/vitest.cjs"
      }
    },
    "./completion": {
      "import": {
        "types": "./dist/completion/index.d.ts",
        "default": "./dist/completion/index.js"
      },
      "require": {
        "types": "./dist/completion/index.d.cts",
        "default": "./dist/completion/index.cjs"
      }
    },
    "./prompt": {
      "import": {
        "types": "./dist/prompt/index.d.ts",
        "default": "./dist/prompt/index.js"
      },
      "require": {
        "types": "./dist/prompt/index.d.cts",
        "default": "./dist/prompt/index.cjs"
      }
    },
    "./prompt/clack": {
      "import": {
        "types": "./dist/prompt/clack/index.d.ts",
        "default": "./dist/prompt/clack/index.js"
      },
      "require": {
        "types": "./dist/prompt/clack/index.d.cts",
        "default": "./dist/prompt/clack/index.cjs"
      }
    },
    "./prompt/inquirer": {
      "import": {
        "types": "./dist/prompt/inquirer/index.d.ts",
        "default": "./dist/prompt/inquirer/index.js"
      },
      "require": {
        "types": "./dist/prompt/inquirer/index.d.cts",
        "default": "./dist/prompt/inquirer/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsgo --incremental",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "string-width": "^8.2.0"
  },
  "devDependencies": {
    "@clack/prompts": "1.2.0",
    "@inquirer/prompts": "8.5.2",
    "@quansync/fs": "1.0.0",
    "@types/node": "25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260527.2",
    "@vitest/coverage-v8": "4.1.8",
    "quansync": "1.0.0",
    "tsdown": "0.22.1",
    "tsx": "4.22.4",
    "vitest": "4.1.8",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "@clack/prompts": "^0.10.0 || ^0.11.0 || ^1.0.0",
    "@inquirer/prompts": "^8.3.2",
    "vitest": "^2 || ^3 || ^4",
    "zod": "^4.2.1"
  },
  "peerDependenciesMeta": {
    "@clack/prompts": {
      "optional": true
    },
    "@inquirer/prompts": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
