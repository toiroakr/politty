{
  "name": "politty",
  "version": "0.4.12",
  "description": "A lightweight CLI framework inspired by citty with zod v4 registry integration for type-safe metadata management",
  "keywords": [
    "argument-parser",
    "cli",
    "command-line",
    "type-safe",
    "typescript",
    "zod"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/toiroakr/politty.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./augment": {
      "import": {
        "types": "./dist/augment.d.ts",
        "default": "./dist/augment.js"
      },
      "require": {
        "types": "./dist/augment.d.cts",
        "default": "./dist/augment.cjs"
      }
    },
    "./docs": {
      "import": {
        "types": "./dist/docs/index.d.ts",
        "default": "./dist/docs/index.js"
      },
      "require": {
        "types": "./dist/docs/index.d.cts",
        "default": "./dist/docs/index.cjs"
      }
    },
    "./completion": {
      "import": {
        "types": "./dist/completion/index.d.ts",
        "default": "./dist/completion/index.js"
      },
      "require": {
        "types": "./dist/completion/index.d.cts",
        "default": "./dist/completion/index.cjs"
      }
    },
    "./prompt": {
      "import": {
        "types": "./dist/prompt/index.d.ts",
        "default": "./dist/prompt/index.js"
      },
      "require": {
        "types": "./dist/prompt/index.d.cts",
        "default": "./dist/prompt/index.cjs"
      }
    },
    "./prompt/clack": {
      "import": {
        "types": "./dist/prompt/clack/index.d.ts",
        "default": "./dist/prompt/clack/index.js"
      },
      "require": {
        "types": "./dist/prompt/clack/index.d.cts",
        "default": "./dist/prompt/clack/index.cjs"
      }
    },
    "./prompt/inquirer": {
      "import": {
        "types": "./dist/prompt/inquirer/index.d.ts",
        "default": "./dist/prompt/inquirer/index.js"
      },
      "require": {
        "types": "./dist/prompt/inquirer/index.d.cts",
        "default": "./dist/prompt/inquirer/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsgo --incremental",
    "lint": "oxlint -c oxlint.json src tests",
    "lint:fix": "oxlint -c oxlint.json --fix src tests",
    "knip": "knip",
    "format": "oxfmt src tests",
    "format:check": "oxfmt --check src tests",
    "organize-imports": "organize-imports-cli tsconfig.json",
    "fix:oxlint": "oxlint -c oxlint.json --fix",
    "fix:oxfmt": "oxfmt",
    "prepare": "lefthook install",
    "prepublishOnly": "pnpm run build",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish"
  },
  "dependencies": {
    "string-width": "^8.2.0"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@clack/prompts": "1.1.0",
    "@inquirer/prompts": "8.3.2",
    "@quansync/fs": "1.0.0",
    "@types/node": "25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260326.1",
    "@vitest/coverage-v8": "4.1.1",
    "knip": "6.0.6",
    "lefthook": "2.1.4",
    "organize-imports-cli": "0.10.0",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "quansync": "1.0.0",
    "tsdown": "0.21.5",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.1",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@clack/prompts": "^0.10.0 || ^0.11.0 || ^1.0.0",
    "@inquirer/prompts": "^8.3.2",
    "zod": "^4.2.1"
  },
  "peerDependenciesMeta": {
    "@clack/prompts": {
      "optional": true
    },
    "@inquirer/prompts": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0"
}
