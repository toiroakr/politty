{
  "name": "@politty/monorepo",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toiroakr/politty.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter politty dev",
    "test": "pnpm -r test",
    "test:watch": "pnpm --filter politty test:watch",
    "test:coverage": "pnpm --filter politty test:coverage",
    "typecheck": "pnpm -r typecheck",
    "lint": "oxlint -c oxlint.json packages/politty/src packages/politty/tests packages/politty-migrate/src",
    "lint:fix": "oxlint -c oxlint.json --fix packages/politty/src packages/politty/tests packages/politty-migrate/src",
    "knip": "knip",
    "format": "oxfmt packages/politty/src packages/politty/tests packages/politty-migrate/src",
    "format:check": "oxfmt --check packages/politty/src packages/politty/tests packages/politty-migrate/src",
    "organize-imports": "organize-imports-cli packages/politty/tsconfig.json",
    "fix:oxlint": "oxlint -c oxlint.json --fix",
    "fix:oxfmt": "oxfmt",
    "prepare": "lefthook install",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "knip": "6.14.2",
    "lefthook": "2.1.8",
    "organize-imports-cli": "1.0.2",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "typescript": "^6.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.4.0"
}
